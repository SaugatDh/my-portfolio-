datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String?
  tags        Json
  demoUrl     String?
  repoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id           Int      @id @default(autoincrement())
  role         String
  company      String
  period       String
  description  String
  technologies Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TechStack {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id        Int      @id @default(autoincrement())
  title     String
  excerpt   String
  date      String
  readTime  String
  slug      String   @unique
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RagContent {
  id        Int      @id @default(autoincrement())
  category  String   @unique  // e.g., "projects", "experience", "skills", "custom"
  content   String   // The text content for this category
  order     Int      @default(0) // For ordering sections
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// We don't need admin_users table as we use Supabase Auth